# Copy to .env and adjust. Every value has a working default for the simulated demo.

# --- Sentinel gate ---
SENTINEL_URL=http://localhost:4000
# Client request timeout (ms). Set >= the gate's SENTINEL_SLOW_BUDGET_MS + margin, so a real
# second-opinion model isn't cut short into a fail-closed BLOCK.
SENTINEL_TIMEOUT_MS=20000
POLICY=fintech.payments
FROM_ACCOUNT=acct_ops          # the agent's funded treasury account (demo ledger)

# --- Autonomous agent (npm run agent) ---
LLM_PROVIDER=anthropic         # anthropic | openai
ANTHROPIC_API_KEY=             # required if LLM_PROVIDER=anthropic
OPENAI_API_KEY=                # required if LLM_PROVIDER=openai
AGENT_MODEL=                   # optional override, e.g. claude-haiku-4-5-20251001 / gpt-4o-mini

# --- Wallet backend ---
# simulated = no keys, fake on-chain settlement (Sentinel gating is REAL)
# live       = real Coinbase CDP wallet on a testnet (needs keys + `npm i @coinbase/cdp-sdk`)
DEMO_MODE=simulated
NETWORK=base-sepolia
LIVE_TESTNET_CAP_USDC=0.1      # live mode settles at most this much on-chain; the gate sees the full amount

# --- Coinbase CDP (only for DEMO_MODE=live; Secret API key needs Non-custodial: Export + Manage) ---
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=

# Live recipients come from the counterparty registry (src/counterparties.ts) — no recipient env needed.
